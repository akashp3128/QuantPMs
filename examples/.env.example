# Kalshi API Credentials
# Get these from https://kalshi.com/settings/api-keys

# Your API Key ID (UUID format)
KALSHI_API_KEY_ID=your-api-key-id-here

# Path to your RSA private key file
KALSHI_PRIVATE_KEY_PATH=/home/node/.openclaw/credentials/kalshi_private_key.pem

# For Docker/OpenClaw container, use:
# KALSHI_PRIVATE_KEY_PATH=/home/node/.openclaw/credentials/kalshi_private_key.pem

# For local development, use:
# KALSHI_PRIVATE_KEY_PATH=$HOME/.openclaw/credentials/kalshi_private_key.pem
